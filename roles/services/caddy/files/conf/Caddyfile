vaultwarden.bl4ckspell.freeddns.org {
	import error_page
	reverse_proxy http://anubis.lan:3000 {
		header_up X-Real-Ip {remote_host}
		header_up X-Http-Version {http.request.proto}
	}
}

# Internal listener for Anubis backend routing

# Managed by Ansible - do not edit on the host.
# Rendered from roles/services/authentik/templates/proxy-apps.yaml.j2
# Source of truth: authentik_proxy_apps in the authentik role defaults.
#
# Providers are forward-auth single-application providers. Caddy decides which
# paths are gated; a provider being listed here does not by itself protect
# anything until a Caddy route imports the `authentik` snippet.
#
# The embedded outpost's provider list is replaced wholesale on every apply, so
# every forward-auth provider must be emitted from this one file.
version: 1
metadata:
  name: proxy-forward-auth-apps
  labels:
    blueprints.goauthentik.io/instantiate: "true"
entries:
{% for app in authentik_proxy_apps %}
{% set host = app.host | default(app.slug ~ '.' ~ authentik_domain) %}
  - model: authentik_providers_proxy.proxyprovider
    id: {{ app.slug }}-provider
    identifiers:
      name: {{ app.slug }}
    attrs:
      name: {{ app.slug }}
      authorization_flow:
        !Find [
          authentik_flows.flow,
          [slug, default-provider-authorization-implicit-consent],
        ]
      invalidation_flow:
        !Find [authentik_flows.flow, [slug, default-provider-invalidation-flow]]
      mode: forward_single
      external_host: https://{{ host }}

  - model: authentik_core.application
    id: {{ app.slug }}-app
    identifiers:
      slug: {{ app.slug }}
    attrs:
      name: {{ app.name | to_json }}
      slug: {{ app.slug }}
      group: {{ app.group | default('Public') | to_json }}
      icon: {{ app.icon | default('https://cdn.jsdelivr.net/gh/selfhst/icons/svg/' ~ app.slug ~ '.svg') | to_json }}
      provider: !KeyOf {{ app.slug }}-provider
      meta_launch_url: https://{{ host }}
      meta_description: {{ app.description | to_json }}

{% endfor %}
  - model: authentik_outposts.outpost
    identifiers:
      name: authentik Embedded Outpost
    attrs:
      providers:
{% for app in authentik_proxy_apps %}
        - !KeyOf {{ app.slug }}-provider
{% endfor %}
